# --- Admin panel ---
NUXT_ADMIN_PASSWORD=change-me-please
NUXT_SESSION_SECRET=generate-a-long-random-string-min-32-chars

# --- Database (SQLite file path) ---
NUXT_DATABASE_URL=./server/db/data/wedding.db

# --- Uploaded images dir (defaults next to the DB; set to the volume in prod) ---
# NUXT_UPLOADS_DIR=/data/uploads

# --- Telegram RSVP notifications (optional) ---
# Create a bot via @BotFather, then get chat id via @userinfobot
NUXT_TELEGRAM_BOT_TOKEN=
NUXT_TELEGRAM_CHAT_ID=

# --- Public site URL (used for OG tags & guest links) ---
NUXT_PUBLIC_SITE_URL=http://localhost:3000
